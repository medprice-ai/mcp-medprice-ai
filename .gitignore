# ==========================================
# Dependencies (Never commit node_modules!)
# ==========================================
node_modules/
jspm_packages/
web_modules/

# ==========================================
# TypeScript & Build Outputs
# ==========================================
# Ignore the folder where TS compiles your JS (usually 'dist' or 'build')
dist/
build/
out/

# Ignore TypeScript build info (used for incremental builds)
*.tsbuildinfo

# ==========================================
# Environment Variables & Secrets
# ==========================================
# Never commit actual credentials or API keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*
! .env.example # DO commit the template/example file

# ==========================================
# Logs and Diagnostics
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================
# Testing & Coverage
# ==========================================
coverage/
.nyc_output/
htmlreport/

# ==========================================
# IDEs and Editors
# ==========================================
# Visual Studio Code
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json

# WebStorm / IntelliJ
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OSX/Linux system files
.DS_Store
Thumbs.db
